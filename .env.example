# M-Engine — variáveis de ambiente (copie para .env e preencha; .env NÃO vai para o git)

# Raiz de dados do runtime (dossiês em $M_BASE/pat, áudio em $M_BASE/audio)
M_BASE=/var/lib/m-engine

# --- Providers LLM (chamadas diretas, sem gateway) ---
# Default de TODOS os stages é Claude Opus 4.8. xAI/DeepSeek só se selecionados explicitamente.
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=

# Provider alternativo de Claude via CLI Claude Code (alias de modelo "cc"):
# spawna `claude -p` e usa a AUTH DO SISTEMA (sessão logada / OAuth / keychain) — NÃO precisa de API key.
# Em VM/systemd, aponte o caminho absoluto do binário (PATH pode não ter ~/.local/bin):
M_CLAUDE_CLI_BIN=claude

# --- Transcrição ---
ELEVENLABS_API_KEY=

# --- Fila / API ---
REDIS_URL=redis://localhost:6379/0
M_API_HOST=0.0.0.0
M_API_PORT=8000

# Override opcional do modelo default (alias: opus|sonnet|haiku|grok|deepseek|deepseekr)
# M_DEFAULT_MODEL=opus
